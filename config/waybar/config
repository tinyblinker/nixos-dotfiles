{
    "position": "top",
    "height": 42,
    "margin": "2 8 0 8",
    "mod": "dock",
    "modules-left": [
        "niri/workspaces",
        "tray"
    ],
    "modules-center": [
        "clock",
        "niri/window"
    ],
    "modules-right": [
        "battery",
        "bluetooth",
        "network",
        "idle_inhibitor",
        "power-profiles-daemon",
        "temperature",
        "pulseaudio",
        "backlight",
        "pulseaudio#microphone"
    ],
    "niri/window": {
        "format": "{app_id}",
        "max-length": 20,
        "icon": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "≤░ΙΙ ",
            "deactivated": "≤░ΙΚ "
        }
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ΎΔπ ",
            "performance": "ΎΔπ ",
            "balanced": "ΎΚΟ ",
            "power-saver": "ΎΒυ "
        }
    },
    "network": {
        "format-wifi": "≤░νρ ",
        "format-ethernet": "≤░ΙΑ ",
        "format-linked": "≤░νσ ",
        "format-disconnected": "≤░νφ ",
        "tooltip-format": "{essid} ({signalStrength}%) - {gwaddr}",
        "tooltip-format-ethernet": "{ifname} - {gwaddr}",
        "tooltip-format-disconnected": "Disconnected"
    },
    "bluetooth": {
        "format": "ΎΛΦ ",
        "format-disabled": "≤░Γ▓!",
        "format-connected": "≤░Γ▒ {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },
    "battery": {
        "full-at": 95,
        "states": { "warning": 35, "critical": 10 },
        "format": "≤░Β╣{capacity}%",
        "format-charging": "≤░ΓΖ {capacity}%",
        "format-plugged": "ΎΘο ",
        "tooltip-format": "{capacity}% {timeTo}"
    },
    "temperature": {
        "format": "ΎΜΚ{temperatureC}┬░C",
        "critical-threshold": 80
    },
    "pulseaudio": {
        "format": "{icon}{volume}%",
        "format-muted": "≤░ζθ 0%",
        "format-icons": {
            "default": ["ΎΑπ ", "ΎΑρ "],
            "headphone": "ΎΑξ ",
            "hands-free": "ΎΛι ",
            "headset": "Ό╣β "
        }
    },
    "clock": {
        "format": "{:%R  %a %m/%d}",
        "tooltip-format": "{calendar}",
        "calendar": {
            "format": {
                "months": "<span color='#D3D04F'><b>{}</b></span>",
                "days": "<span color='#93B1A6'><b>{}</b></span>",
                "weekdays": "<span color='#8EAC50'><b>{}</b></span>",
                "today": "<span color='#8EAC50'><b><u>{}</u></b></span>"
            }
        }
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "≤░Δθ {percent}%",
        "min-length": 6
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ "
    },
    "tray": { "icon-size": 20, "spacing": 20 }
}
