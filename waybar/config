{
    "position": "top",
    "height": 42,
    "margin": "2 8 0 8",
    "mod": "dock",
    "modules-left": [
        "niri/workspaces",
        "tray"
    ],
    "modules-center": [
        "clock",
        "niri/window"
    ],
    "modules-right": [
        "battery",
        "bluetooth",
        "network",
        "idle_inhibitor",
        "power-profiles-daemon",
        "temperature",
        "pulseaudio",
        "backlight",
        "pulseaudio#microphone"
    ],
    "niri/window": {
        "format": "{app_id}",
        "max-length": 20,
        "icon": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "\uf06e",
            "deactivated": "\uf186"
        }
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "\uf0e7",
            "performance": "\uf0e7",
            "balanced": "\uf24e",
            "power-saver": "\uf1f4"
        }
    },
    "network": {
        "format-icons": ["\uf1eb", "\uf1ec", "\uf1ed", "\uf1ee"],
        "format-wifi": "{icon} {signalStrength}%",
        "format-ethernet": "\uf796",
        "format-linked": "\uf127",
        "format-disconnected": "\uf6fa",
        "tooltip-format": "{essid} ({signalStrength}%) - {gwaddr}",
        "tooltip-format-ethernet": "{ifname} - {gwaddr}",
        "tooltip-format-disconnected": "Disconnected"
    },
    "bluetooth": {
        "format": "\uf293",
        "format-disabled": "\uf295",
        "format-connected": "\uf293 {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },
    "battery": {
        "full-at": 95,
        "states": { "warning": 35, "critical": 10 },
        "format": "{icon} {capacity}%",
        "format-plugged": "\uf1e6 AC",
        "format-charging": "\uf1e6",
        "format-icons": ["\uf244","\uf243","\uf242","\uf241","\uf240","\uf23f","\uf23e","\uf23d","\uf23c","\uf23b","\uf1d9"],
        "tooltip-format": "{capacity}% {timeTo} {time}"
    },
    "temperature": {
        "format": "\uf2c9 {temperatureC}°C",
        "critical-threshold": 80
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "\uf6a9  0%",
        "format-icons": {
            "default": ["\uf027", "\uf028"],
            "headphone": "\uf87b",
            "hands-free": "\uf87b",
            "headset": "\uf87b"
        }
    },
    "clock": {
        "format": "{:%R  %a %m/%d}",
        "tooltip-format": "{calendar}",
        "calendar": {
            "format": {
                "months": "<span color='#D3D04F'><b>{}</b></span>",
                "days": "<span color='#93B1A6'><b>{}</b></span>",
                "weekdays": "<span color='#8EAC50'><b>{}</b></span>",
                "today": "<span color='#8EAC50'><b><u>{}</u></b></span>"
            }
        }
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "\uf0eb  {percent}%",
        "min-length": 6
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "\uf130  {volume}%",
        "format-source-muted": "\uf131"
    },
    "tray": { "icon-size": 20, "spacing": 20 }
}
